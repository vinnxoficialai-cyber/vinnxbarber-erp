{
    "crons": [
        {
            "path": "/api/subscription-cron",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/subscription-reconcile",
            "schedule": "0 4 * * *"
        },
        {
            "path": "/api/push-cron-daily",
            "schedule": "0 12 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/manifest.webmanifest",
            "destination": "/api/manifest"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}
